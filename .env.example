# ---- Database ----
# Default values match docker-compose.yml
POSTGRES_USER=alpharag
POSTGRES_PASSWORD=alpharag
POSTGRES_DB=alpharag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://alpharag:alpharag@localhost:5432/alpharag
# Sync URL is only used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://alpharag:alpharag@localhost:5432/alpharag

# ---- LLM / Embeddings ----
OPENAI_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---- SEC EDGAR ----
# EDGAR's fair-access policy REQUIRES a User-Agent containing your contact email.
# Replace with your real name + email before running ingestion.
SEC_USER_AGENT=AlphaRAG Research alpharag@example.com
SEC_REQUESTS_PER_SECOND=8

# ---- Ingestion policy ----
INGEST_FRESHNESS_DAYS=7
INGEST_NUM_10K=1
INGEST_NUM_10Q=2
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
